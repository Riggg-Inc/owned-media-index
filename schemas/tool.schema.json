{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Riggg-Inc/owned-media-index/schemas/tool.schema.json",
  "title": "Owned Media Tool",
  "type": "object",
  "required": ["name", "category", "purpose", "bestFor", "score"],
  "properties": {
    "name": { "type": "string" },
    "website": { "type": "string" },
    "category": { "type": "string" },
    "purpose": { "type": "string" },
    "bestFor": {
      "type": "array",
      "items": { "type": "string" }
    },
    "pricingTier": { "type": "string" },
    "alternatives": {
      "type": "array",
      "items": { "type": "string" }
    },
    "score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "notes": { "type": "string" }
  }
}

